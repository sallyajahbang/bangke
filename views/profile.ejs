<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <title>Profil: <%= data.profile.user.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-zinc-950 text-zinc-300 font-sans antialiased overflow-x-hidden">
    <nav class="sticky top-0 z-50 backdrop-blur-md bg-zinc-900/75 border-b border-emerald-950/80 shadow-sm px-4 py-3">
        <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-3">
            <div class="flex justify-between items-center w-full sm:w-auto shrink-0">
                <a href="/" class="text-lg font-black bg-gradient-to-r from-emerald-400 to-teal-500 bg-clip-text text-transparent tracking-tight">
                    Rimuru Explorer
                </a>
                <a href="javascript:history.back()" class="text-xs font-semibold text-zinc-400 sm:hidden bg-zinc-800 px-3 py-1.5 rounded-lg active:bg-zinc-700">Kembali</a>
            </div>
            
            <form action="/search" method="GET" class="w-full flex gap-2 sm:max-w-md">
                <input type="text" name="q" placeholder="Cari karya kreator ini..." class="w-full px-4 py-2.5 bg-zinc-800/40 border border-zinc-700 rounded-xl focus:outline-none focus:bg-zinc-900 focus:border-emerald-500 text-zinc-100 text-base md:text-sm transition-all duration-300">
                <button type="submit" class="bg-gradient-to-r from-emerald-400 to-teal-500 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 shrink-0 active:scale-95">Cari</button>
            </form>
            
            <a href="javascript:history.back()" class="hidden sm:inline-block text-sm font-medium text-zinc-400 hover:text-zinc-300">Kembali</a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-4 py-6 sm:py-8">
        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-5 sm:p-8 mb-6 text-center shadow-sm relative overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-emerald-400 via-emerald-500 to-teal-600"></div>
            
            <img src="/proxy?url=<%= encodeURIComponent(data.profile.user.profile_image_urls.medium) %>" class="w-20 h-20 sm:w-24 sm:h-24 rounded-full mx-auto mb-3 border-4 border-zinc-900 ring-4 ring-emerald-950 object-cover shadow-sm">
            <h1 class="text-xl font-bold text-zinc-100 tracking-tight"><%= data.profile.user.name %></h1>
            <span class="inline-block mt-1.5 bg-emerald-950 text-emerald-400 text-xs font-semibold px-3 py-0.5 rounded-full border border-emerald-900/50">
                <%= data.profile.profile.total_illusts %> Artworks Koleksi
            </span>
            <p class="text-xs sm:text-sm text-zinc-400 mt-3.5 max-w-2xl mx-auto leading-relaxed break-words px-2"><%= data.profile.user.comment %></p>
        </div>

        <h2 class="text-base font-bold text-zinc-100 mb-4 tracking-tight border-b border-zinc-800 pb-2">Galeri Karya Terbaru</h2>
        
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-5">
            <% data.illusts.forEach(art => { %>
                <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden shadow-sm flex flex-col justify-between group active:bg-zinc-800/50">
                    <a href="/artwork/<%= art.id %>" class="block relative bg-zinc-950">
                        <img src="/proxy?url=<%= encodeURIComponent(art.image_urls.medium) %>" class="w-full h-44 sm:h-52 md:h-60 object-cover">
                        
                        <% if (art.tags && (art.tags.includes('R-18') || art.tags.includes('R18'))) { %>
                            <span class="absolute top-2.5 left-2.5 bg-rose-600/90 backdrop-blur-sm text-white text-[9px] sm:text-[10px] font-black px-1.5 py-0.5 rounded-lg shadow-sm tracking-wider">R-18</span>
                        <% } %>

                        <span class="absolute top-2.5 right-2.5 bg-zinc-900/80 backdrop-blur-sm text-zinc-300 text-[9px] sm:text-[10px] font-medium px-1.5 py-0.5 rounded-lg shadow-sm border border-zinc-700/50">
                            <%= art.pageCount %> Pgs
                        </span>
                    </a>
                    <div class="p-3">
                        <h3 class="text-xs sm:text-sm font-semibold text-zinc-100 truncate"><%= art.title %></h3>
                        <p class="text-[11px] text-emerald-400 font-medium mt-1 flex items-center gap-1">
                            Penanda: <%= art.total_bookmarks %>
                        </p>
                    </div>
                </div>
            <% }) %>
        </div>
    </main>
</body>
</html>