<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <title>Profil: <%= data.profile.user.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-black text-zinc-300 font-sans antialiased overflow-x-hidden">
    <nav class="sticky top-0 z-50 backdrop-blur-md bg-zinc-950/80 border-b border-red-950 shadow-[0_4px_20px_rgba(185,28,28,0.15)] px-4 py-3">
        <div class="max-w-6xl mx-auto flex flex-col sm:flex-row justify-between items-center gap-3">
            <div class="flex justify-between items-center w-full sm:w-auto shrink-0">
                <a href="/" class="text-lg font-black bg-gradient-to-r from-red-500 to-rose-600 bg-clip-text text-transparent tracking-tight drop-shadow">
                    Rimuru Explorer
                </a>
                <a href="javascript:history.back()" class="text-xs font-semibold text-zinc-400 sm:hidden bg-zinc-900 px-3 py-1.5 rounded-lg border border-zinc-800 active:bg-zinc-800">Kembali</a>
            </div>
            
            <form action="/search" method="GET" class="w-full flex gap-2 sm:max-w-md">
                <input type="text" name="q" placeholder="Cari karya kreator ini..." class="w-full px-4 py-2.5 bg-zinc-900/40 border border-zinc-800 rounded-xl focus:outline-none focus:bg-zinc-950 focus:border-red-700 text-zinc-100 text-base md:text-sm transition-all duration-300">
                <button type="submit" class="bg-gradient-to-r from-red-700 to-rose-900 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-300 shrink-0 active:scale-95 shadow-[0_0_10px_rgba(185,28,28,0.3)]">Cari</button>
            </form>
            
            <a href="javascript:history.back()" class="hidden sm:inline-block text-sm font-medium text-zinc-400 hover:text-zinc-200">Kembali</a>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-4 py-6 sm:py-8">
        <div class="bg-zinc-950 border border-zinc-900 rounded-2xl p-5 sm:p-8 mb-6 text-center shadow-sm relative overflow-hidden">
            <div class="absolute top-0 left-0 right-0 h-1.5 bg-gradient-to-r from-red-700 via-red-600 to-rose-900"></div>
            
            <img src="/proxy?url=<%= encodeURIComponent(data.profile.user.profile_image_urls.medium) %>" class="w-20 h-20 sm:w-24 sm:h-24 rounded-full mx-auto mb-3 border-4 border-zinc-950 ring-4 ring-red-950 object-cover shadow-sm">
            <h1 class="text-xl font-bold text-zinc-100 tracking-tight drop-shadow"><%= data.profile.user.name %></h1>
            <span class="inline-block mt-1.5 bg-red-950/40 text-red-400 text-xs font-semibold px-3 py-0.5 rounded-full border border-red-900/50">
                <%= data.profile.profile.total_illusts %> Artworks Koleksi
            </span>
            <p class="text-xs sm:text-sm text-zinc-400 mt-3.5 max-w-2xl mx-auto leading-relaxed break-words px-2"><%= data.profile.user.comment %></p>
        </div>

        <h2 class="text-base font-bold text-zinc-100 mb-4 tracking-tight border-b border-red-950 pb-2">Galeri Karya Terbaru</h2>
        
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3 sm:gap-5">
            <% data.illusts.forEach(art => { %>
                <div class="bg-zinc-950 border border-zinc-900 rounded-2xl overflow-hidden shadow-sm flex flex-col justify-between group active:border-red-900 transition-all duration-300">
                    <a href="/artwork/<%= art.id %>" class="block relative bg-black">
                        <img src="/proxy?url=<%= encodeURIComponent(art.image_urls.medium) %>" class="w-full h-44 sm:h-52 md:h-60 object-cover">
                        
                        <% if (art.tags && (art.tags.includes('R-18') || art.tags.includes('R18'))) { %>
                            <span class="absolute top-2.5 left-2.5 bg-red-600/90 backdrop-blur-sm text-white text-[9px] sm:text-[10px] font-black px-1.5 py-0.5 rounded-lg shadow-sm tracking-wider">R-18</span>
                        <% } %>

                        <span class="absolute top-2.5 right-2.5 bg-black/80 backdrop-blur-sm text-red-400 text-[9px] sm:text-[10px] font-medium px-1.5 py-0.5 rounded-lg shadow-sm border border-red-950">
                            <%= art.pageCount %> Pgs
                        </span>
                    </a>
                    <div class="p-3 bg-zinc-950">
                        <h3 class="text-xs sm:text-sm font-semibold text-zinc-100 truncate group-hover:text-red-400 transition-colors"><%= art.title %></h3>
                        <p class="text-[11px] text-red-500 font-medium mt-1 flex items-center gap-1">
                            Penanda: <%= art.total_bookmarks %>
                        </p>
                    </div>
                </div>
            <% }) %>
        </div>

        <div class="flex justify-center items-center gap-2 mt-8 border-t border-zinc-900 pt-6">
            <button onclick="changePage('prev')" class="bg-zinc-950 hover:bg-zinc-900 text-red-400 text-xs font-semibold px-4 py-2.5 rounded-xl border border-red-950 transition-all disabled:opacity-40 disabled:cursor-not-allowed" id="btnPrev">
                Sebelumnya
            </button>
            <span class="text-xs font-bold text-zinc-400 bg-zinc-950 border border-zinc-900 px-4 py-2.5 rounded-xl" id="pageIndicator">
                Halaman 1
            </span>
            <button onclick="changePage('next')" class="bg-gradient-to-r from-red-700 to-rose-900 hover:from-red-600 hover:to-rose-800 text-white text-xs font-semibold px-4 py-2.5 rounded-xl shadow-sm transition-all active:scale-95" id="btnNext">
                Berikutnya
            </button>
        </div>
    </main>

    <script>
        // Logika sederhana untuk manajemen parameter halaman di URL
        const urlParams = new URLSearchParams(window.location.search);
        let currentPage = parseInt(urlParams.get('page')) || 1;

        // Memperbarui tampilan nomor halaman saat dimuat
        document.getElementById('pageIndicator').innerText = `Halaman ${currentPage}`;
        
        if (currentPage <= 1) {
            document.getElementById('btnPrev').disabled = true;
        }

        function changePage(direction) {
            if (direction === 'prev' && currentPage > 1) {
                currentPage--;
            } else if (direction === 'next') {
                currentPage++;
            }
            
            urlParams.set('page', currentPage);
            window.location.search = urlParams.toString();
        }
    </script>
</body>
</html>
